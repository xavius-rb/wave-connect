<div id="<%= dom_id(service) %>" class="p-6 bg-white shadow rounded-lg mb-6">
  <div class="mb-4">
    <h2 class="text-xl font-semibold text-gray-800 mb-2">
      <%= link_to service.name, service, class: "text-indigo-600 hover:text-indigo-800 hover:underline" %>
    </h2>
    <div class="flex items-center space-x-2 text-sm text-gray-500">
      <p>UUID: <span id="uuid-<%= service.id %>"><%= service.uuid %></span></p>
      <button
        onclick="copyToClipboard('<%= service.uuid %>', this)"
        class="text-indigo-600 hover:text-indigo-800 focus:outline-none">
        Copy
      </button>
    </div>
  </div>

  <div class="mb-4">
    <h3 class="text-lg font-medium text-gray-700">Repository URL</h3>
    <p class="text-gray-600">
      <%= link_to service.repository_url, service.repository_url, class: "text-blue-600 hover:underline break-all" %>
    </p>
  </div>
</div>

<script>
  function copyToClipboard(text, button) {
    navigator.clipboard.writeText(text).then(function() {
      button.textContent = 'Copied!';
      setTimeout(function() {
        button.textContent = 'Copy';
      }, 2000);
    }, function(err) {
      console.error('Could not copy text: ', err);
    });
  }
</script>
